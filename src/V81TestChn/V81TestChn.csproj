    <None Include="..\..\assets\textures\zh-CN\Texture\EndgameAllPlayersDeadOverlay.png" CopyToOutputDirectory="PreserveNewest" Link="textures\EndgameAllPlayersDeadOverlay.png" Condition="Exists('..\..\assets\textures\zh-CN\Texture\EndgameAllPlayersDeadOverlay.png')" />
    <None Include="..\..\assets\textures\zh-CN\Texture\EndgameStatsBoxesLocalized.png" CopyToOutputDirectory="PreserveNewest" Link="textures\EndgameStatsBoxesLocalized.png" Condition="Exists('..\..\assets\textures\zh-CN\Texture\EndgameStatsBoxesLocalized.png')" />
    <None Include="..\..\assets\textures\zh-CN\Texture\EndgameStatsDeceased.png" CopyToOutputDirectory="PreserveNewest" Link="textures\EndgameStatsDeceased.png" Condition="Exists('..\..\assets\textures\zh-CN\Texture\EndgameStatsDeceased.png')" />
    <None Include="..\..\assets\textures\zh-CN\Texture\EndgameStatsMissing.png" CopyToOutputDirectory="PreserveNewest" Link="textures\EndgameStatsMissing.png" Condition="Exists('..\..\assets\textures\zh-CN\Texture\EndgameStatsMissing.png')" />
