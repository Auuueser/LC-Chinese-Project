  <Target Name="CleanOverlayArtifacts" AfterTargets="Build">
    <ItemGroup>
      <LocalOverlayArtifacts Include="$(TargetDir)textures\EnteringAtmosphereOverlay.png" />
      <LocalOverlayArtifacts Include="$(TargetDir)overlays\zh-cn-overlays" />
      <LocalOverlayArtifacts Include="$(TargetDir)overlays\zh-cn-overlays.manifest" />
      <DistOverlayArtifacts Include="..\..\dist\BepInEx\plugins\V81TestChn\textures\EnteringAtmosphereOverlay.png" Condition="Exists('..\..\dist\BepInEx\plugins\V81TestChn')" />
      <DistOverlayArtifacts Include="..\..\dist\BepInEx\plugins\V81TestChn\overlays\zh-cn-overlays" Condition="Exists('..\..\dist\BepInEx\plugins\V81TestChn')" />
      <DistOverlayArtifacts Include="..\..\dist\BepInEx\plugins\V81TestChn\overlays\zh-cn-overlays.manifest" Condition="Exists('..\..\dist\BepInEx\plugins\V81TestChn')" />
      <TestOverlayArtifacts Include="$(TestDeployDir)\textures\EnteringAtmosphereOverlay.png" Condition="'$(TestDeployDir)' != ''" />
      <TestOverlayArtifacts Include="$(TestDeployDir)\overlays\zh-cn-overlays" Condition="'$(TestDeployDir)' != ''" />
      <TestOverlayArtifacts Include="$(TestDeployDir)\overlays\zh-cn-overlays.manifest" Condition="'$(TestDeployDir)' != ''" />
    </ItemGroup>
    <Delete Files="@(LocalOverlayArtifacts)" />
    <Delete Files="@(DistOverlayArtifacts)" />
    <Delete Files="@(TestOverlayArtifacts)" />
    <RemoveDir Directories="$(TargetDir)overlays" Condition="Exists('$(TargetDir)overlays')" />
    <RemoveDir Directories="..\..\dist\BepInEx\plugins\V81TestChn\overlays" Condition="Exists('..\..\dist\BepInEx\plugins\V81TestChn\overlays')" />
    <RemoveDir Directories="$(TestDeployDir)\overlays" Condition="'$(TestDeployDir)' != '' and Exists('$(TestDeployDir)\overlays')" />
  </Target>

  <Target Name="SyncPluginOutputToDist" AfterTargets="Build" Condition="Exists('..\..\dist\BepInEx\plugins')">
    <ItemGroup>
      <PluginOutput Include="$(TargetDir)**\*" />
    </ItemGroup>
    <MakeDir Directories="..\..\dist\BepInEx\plugins\V81TestChn" />
    <Copy
      SourceFiles="@(PluginOutput)"
      DestinationFiles="@(PluginOutput->'..\..\dist\BepInEx\plugins\V81TestChn\%(RecursiveDir)%(Filename)%(Extension)')"
      SkipUnchangedFiles="true" />
  </Target>

  <Target Name="SyncPluginOutputToTestDeploy" AfterTargets="Build" Condition="'$(TestDeployDir)' != ''">
    <ItemGroup>
      <PluginOutput Include="$(TargetDir)**\*" />
    </ItemGroup>
    <MakeDir Directories="$(TestDeployDir)" />
    <Copy
      SourceFiles="@(PluginOutput)"
      DestinationFiles="@(PluginOutput->'$(TestDeployDir)\%(RecursiveDir)%(Filename)%(Extension)')"
      SkipUnchangedFiles="true" />
  </Target>
</Project>
