    <None Include="..\..\LeKAKiD-FontPatcher-1.2.4\config\FontPatcher\default\*" CopyToOutputDirectory="PreserveNewest" Link="fontpatcher\default\%(Filename)%(Extension)" Condition="Exists('..\..\LeKAKiD-FontPatcher-1.2.4\config\FontPatcher\default')" />
